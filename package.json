{
  "name": "bounced",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --base=/bounced/",
    "predeploy": "npm run build:pages",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --base=/bounced/",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
